# --- eSSL / ZKTeco device ---
DEVICE_IP=192.168.1.201
DEVICE_PORT=4370
DEVICE_PASSWORD=0
DEVICE_TIMEOUT=10
DEVICE_FORCE_UDP=false

# --- Frappe / ERPNext site ---
FRAPPE_URL=https://your-site.example.com
FRAPPE_API_KEY=your_api_key
FRAPPE_API_SECRET=your_api_secret

# --- Sync behaviour ---
# How many days back to look on the very first run (no previous sync state yet)
INITIAL_SYNC_DAYS=7
# Clear device logs after successful sync (true/false). Leave false until you trust the pipeline.
CLEAR_DEVICE_LOGS=false
# Polling interval in minutes when running in continuous (--run) mode
POLL_INTERVAL_MINUTES=5

# --- Logging ---
# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO